# Backend base URL — where Vite dev proxy forwards /api requests.
# Point at http://107.23.122.99 to hit the deployed instance instead of local.
VITE_API_BASE_URL=http://localhost:8000

# Auth note: the SPA now uses a real login flow (POST /api/auth/login/) that
# returns a JWT stored in localStorage. No credentials are baked into the
# client bundle at build time — users sign in from the login screen.
